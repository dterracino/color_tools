    vec3(0.0000, 0.3098, 0.0314),  // nes_43 #004f08
    vec3(0.0000, 0.5647, 0.1961),  // nes_44 #009032
    vec3(0.2706, 0.8824, 0.5098),  // nes_45 #45e182
