// NES Palette Shader
// =============================================================================
// Quantises every pixel to the closest colour in the NES master palette (54
// colours, NTSC canonical set from the color_tools library).
//
// The nearest-colour search is done entirely in linear RGB so the result
// matches what color_tools.distance.euclidean() would return.  For an even
// more perceptually accurate match swap the distance function below to the
// CIE76 / CIEDE2000 version (commented out at the bottom of this file).
//
// Uniforms
//   u_texture   – the source image / video frame (sampler2D)
//   u_pixelate  – optional pixelation factor (1 = off, 4 = 4×4 pixel blocks)
//   u_dither    – dither strength  0.0 = off, 1.0 = full Bayer 4×4
//
// How to copy this shader to another project:
//   1. Copy this file.
//   2. Bind u_texture to your source image/video.
//   3. (Optional) set u_pixelate and u_dither.
//   4. Render a fullscreen quad with quad.vert.
//
// Palette source: color_tools data/palettes/nes.json
// Generated by:   demos/palette_shader_demo.py
// =============================================================================

#version 330 core

in  vec2  v_texcoord;
out vec4  fragColor;

uniform sampler2D u_texture;
uniform float     u_pixelate; // default 4.0  (NES res ~256x224 → block=2–4)
uniform float     u_dither;   // default 0.0

// ---------------------------------------------------------------------------
// NES 54-colour palette (linear RGB, derived from color_tools nes.json)
// ---------------------------------------------------------------------------
const int NES_SIZE = 54;
const vec3 NES_PALETTE[54] = vec3[54](
    vec3(0.0000, 0.0000, 0.0000),  // nes_00 #000000
    vec3(0.4000, 0.4000, 0.4000),  // nes_01 #666666
    vec3(0.6824, 0.6824, 0.6824),  // nes_02 #aeaeae
    vec3(0.0000, 0.1647, 0.5333),  // nes_03 #002a88
    vec3(0.0824, 0.3725, 0.8549),  // nes_04 #155fda
    vec3(0.3922, 0.6902, 0.9961),  // nes_05 #64b0fe
    vec3(0.7569, 0.8784, 0.9961),  // nes_06 #c1e0fe
    vec3(0.0784, 0.0706, 0.6588),  // nes_07 #1412a8
    vec3(0.2588, 0.2510, 0.9961),  // nes_08 #4240fe
    vec3(0.5765, 0.5647, 0.9961),  // nes_09 #9390fe
    vec3(0.8314, 0.8275, 0.9961),  // nes_10 #d4d3fe
    vec3(0.2314, 0.0000, 0.6431),  // nes_11 #3b00a4
    vec3(0.4627, 0.1529, 1.0000),  // nes_12 #7627ff
    vec3(0.7804, 0.4667, 0.9961),  // nes_13 #c777fe
    vec3(0.9137, 0.7843, 0.9961),  // nes_14 #e9c8fe
    vec3(0.3608, 0.0000, 0.4941),  // nes_15 #5c007e
