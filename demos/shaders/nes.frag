// ---------------------------------------------------------------------------
// Bayer 4×4 ordered dither matrix (normalised to [-0.5, 0.5])
// ---------------------------------------------------------------------------
float bayer4x4(ivec2 p) {
    int x = p.x & 3;
    int y = p.y & 3;
    // Standard Bayer 4×4 thresholds (0–15), normalised to [-0.5, 0.5]
    int idx = (y * 4 + x);
    float[16] M = float[16](
         0.0,  8.0,  2.0, 10.0,
        12.0,  4.0, 14.0,  6.0,
         3.0, 11.0,  1.0,  9.0,
        15.0,  7.0, 13.0,  5.0
    );
    return (M[idx] / 16.0) - 0.5;   // range [-0.5, 0.5]
}

// ---------------------------------------------------------------------------
// Nearest-colour search in linear RGB space
// (identical to color_tools.distance.euclidean)
// ---------------------------------------------------------------------------
vec3 nearest_nes(vec3 color) {
    float best_dist = 1e9;
    vec3  best_col  = NES_PALETTE[0];
    for (int i = 0; i < NES_SIZE; i++) {
        vec3  delta = color - NES_PALETTE[i];
        float dist  = dot(delta, delta);   // squared Euclidean – no need for sqrt
        if (dist < best_dist) {
            best_dist = dist;
            best_col  = NES_PALETTE[i];
        }
    }
    return best_col;
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------
void main() {
    // Optional pixel-block quantisation (emulates low resolution)
    vec2 uv = v_texcoord;
    if (u_pixelate > 1.0) {
        vec2 texSize  = vec2(textureSize(u_texture, 0));
        vec2 blockSize = vec2(u_pixelate) / texSize;
        uv = (floor(uv / blockSize) + 0.5) * blockSize;
    }

    vec3 color = texture(u_texture, uv).rgb;

    // Optional Bayer dither (perturbs the colour before quantisation)
    if (u_dither > 0.0) {
        ivec2 px = ivec2(gl_FragCoord.xy);
        float noise = bayer4x4(px) * u_dither * (1.0 / float(NES_SIZE));
        color = clamp(color + vec3(noise), 0.0, 1.0);
    }

    fragColor = vec4(nearest_nes(color), 1.0);
}

