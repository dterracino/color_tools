    vec3(0.9843, 0.7647, 0.9961),  // nes_18 #fbc3fe
    vec3(0.4314, 0.0000, 0.2510),  // nes_19 #6e0040
    vec3(0.7216, 0.1176, 0.4863),  // nes_20 #b81e7c
