# PyPI API Token Configuration
# Copy this file to .env and add your actual API token
# NEVER commit .env to git (it's in .gitignore)

# Get your PyPI API token from: https://pypi.org/manage/account/token/
# Format: pypi-AgEIcHlwaS5vcmcC... (starts with "pypi-")
PYPI_API_KEY=your-pypi-api-token-here

# For TestPyPI (optional, for testing before real upload)
# Get from: https://test.pypi.org/manage/account/token/
TESTPYPI_API_KEY=your-test-pypi-api-token-here

# Codecov API Token Configuration (optional, for code coverage reporting)
# Get your Codecov API token from: https://app.codecov.io/account
CODECOV_API_KEY=your-codecov-api-token-here

# Vercel API Token Configuration (optional, for deployment)
# Get your Vercel API token from: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-api-token-here

# Vercel Org/Team ID (optional, for deployment)
# Get your Vercel Org/Team ID from: https://vercel.com/account/teams
VERCEL_ORG_ID=your-vercel-org-id-here

# Vercel Project ID (optional, for deployment)
# Get your Vercel Project ID from: https://vercel.com/dashboard
VERCEL_PROJECT_ID=your-vercel-project-id-here

# Context7 API Key Configuration (optional, for Context7 integration)
# Get your Context7 API key from: https://context7.com/account/api-keys
CONTEXT7_API_KEY=your-context7-api-key-here